rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getRole() {
      return getUserDoc(request.auth.uid).role;
    }

    function isChiefExec() {
      return isSignedIn() && getRole() == "chief_exec";
    }

    // System Admin: same operational reach as Chief Exec (all departments'
    // data, all approvals) except role assignment — see isChiefExec-only rules below.
    function isSystemAdmin() {
      return isSignedIn() && getRole() == "system_admin";
    }

    function isDeptHeadOrAbove() {
      return isSignedIn() && getRole() in ["chief_exec", "system_admin", "department_head"];
    }

    // Committee ("Event Support") otherwise has no dashboard access — this is
    // the one read-only exception, for the membership lookup tool.
    function isCommitteeOrAbove() {
      return isSignedIn() &&
        getRole() in ["chief_exec", "system_admin", "department_head", "committee"];
    }

    function isActiveMember() {
      return isSignedIn() && getUserDoc(request.auth.uid).membershipStatus == "active";
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- users: role/status are admin-managed only, never self-writable ---
    match /users/{uid} {
      allow read: if isOwner(uid) || isCommitteeOrAbove();
      // Role reassignment is Chief Exec only; everything else about a user
      // (status, tier) is written via reviewed admin actions, never by the
      // client directly — see server-side API routes.
      allow write: if false;
    }

    match /memberProfiles/{uid} {
      allow read: if isOwner(uid) || isDeptHeadOrAbove();
      allow create: if isOwner(uid) && request.resource.data.consentGiven == true;
      allow update: if isOwner(uid) || isDeptHeadOrAbove();
    }

    match /membershipTerms/{termId} {
      allow read: if isSignedIn();
      allow write: if isChiefExec() || isSystemAdmin();
    }

    match /membershipRenewals/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isDeptHeadOrAbove());
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isDeptHeadOrAbove();
    }

    match /paymentProofs/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isDeptHeadOrAbove());
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isDeptHeadOrAbove();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isDeptHeadOrAbove();
    }

    match /rsvps/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isDeptHeadOrAbove());
      allow create: if isOwner(request.resource.data.uid) && isActiveMember();
      // Check-in toggle is admin-only.
      allow update: if isDeptHeadOrAbove();
    }

    match /responsibilities/{id} {
      allow read: if isSignedIn() &&
        (resource.data.assignedTo == request.auth.uid || isDeptHeadOrAbove());
      allow create, update: if isDeptHeadOrAbove();
    }

    match /performanceReviews/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isDeptHeadOrAbove());
      allow create, update: if isDeptHeadOrAbove();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isDeptHeadOrAbove();
    }

    match /orgKpis/{id} {
      allow read: if isSignedIn();
      allow write: if isChiefExec() || isSystemAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isDeptHeadOrAbove();
    }

    // Guest checkout has no auth to scope a rule against, so — unlike every
    // other collection here — orders are written exclusively through the
    // server action (Admin SDK, which bypasses rules) after zod validation,
    // never directly from the client. Locking client writes to false here is
    // what keeps an unauthenticated flow from being an open write endpoint.
    match /merchOrders/{id} {
      allow read: if isDeptHeadOrAbove();
      allow create, update: if false;
    }

    // Membership applications: submitted before any account exists, so same
    // pattern as merchOrders — no auth to scope a client rule against, write
    // exclusively through the server action after zod validation (including
    // the @adzu.edu.ph domain check, done manually here since there's no
    // Firebase Auth token yet to rely on for that).
    match /applications/{id} {
      allow read: if isDeptHeadOrAbove();
      allow create, update: if false;
    }
  }
}
