rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function isDeptHeadOrAbove() {
      return isSignedIn() && getRole() in ["chief_exec", "system_admin", "department_head"];
    }

    // Payment proof screenshots: owner can upload their own, admins can view all for review.
    match /paymentProofs/{uid}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isDeptHeadOrAbove());
      allow write: if isSignedIn() && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    // Guest merch checkout has no account to scope against — write is open
    // (size/type restricted) by necessity, same tradeoff accepted for the
    // guest-checkout decision. Only admins can read it back for order review.
    match /merchOrders/{fileName} {
      allow read: if isDeptHeadOrAbove();
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }
  }
}
